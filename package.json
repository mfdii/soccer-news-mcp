{
  "name": "soccer-news-mcp",
  "version": "1.0.0",
  "description": "MCP server for soccer news with RAG and sentiment analysis",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "migrate": "tsx src/database/migrations/migrate.ts",
    "seed": "tsx scripts/seed-sources.ts",
    "seed-quotes": "tsx scripts/seed-quotes.ts",
    "load-quotes": "tsx scripts/load-additional-quotes.ts",
    "test": "vitest",
    "test:feeds": "tsx scripts/test-feeds.ts",
    "rebuild-embeddings": "tsx scripts/rebuild-embeddings.ts",
    "fetch-feeds": "tsx scripts/fetch-all-feeds.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@xenova/transformers": "^2.17.2",
    "pg": "^8.13.1",
    "rss-parser": "^3.13.0",
    "express": "^4.21.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/express": "^4.17.21"
  }
}
